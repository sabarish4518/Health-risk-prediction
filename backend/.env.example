# ==================== .ENV.EXAMPLE ====================
# Environment Variables for Student Health Risk Prediction System
# Copy this file to .env and update with your values

# Server Configuration
PORT=5000
NODE_ENV=development

# Quick Login Mode (skips DB and enables fixed login credentials)
QUICK_LOGIN_ONLY=true
QUICK_LOGIN_USERNAME=student
QUICK_LOGIN_PASSWORD=student123

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=student_health_db
DB_PORT=3306

# JWT Configuration
SECRET_KEY=your-secret-key-change-this-in-production

# Admin Default Credentials (Change after first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
